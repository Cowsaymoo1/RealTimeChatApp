{
  "openapi": "3.0.0",
  "info": {
    "title": "chatapp",
    "version": "1.0.0",
    "description": ""
  },
  "servers": [
    {
      "url": "http://localhost:5001/api"
    }
  ],
  "paths": {
    "/auth/signup": {
      "post": {
        "tags": ["Auth"],
        "summary": "SignUp",
        "description": "Create a new user account. Returns 201 on success or 409 when username/email already exists.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SignUpRequest" },
              "example": {
                "userName": "user2",
                "password": "123456",
                "email": "user2@example.com",
                "firstName": "User",
                "lastName": "Two"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "message": { "type": "string" } }
                },
                "example": { "message": "User created successfully" }
              }
            }
          },
          "400": { "description": "Bad Request - missing/invalid fields" },
          "409": {
            "description": "Conflict - username or email already exists",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "message": "email already exists" }
              }
            }
          },
          "500": { "description": "Server error" }
        }
      }
    },
    "/auth/signin": {
      "post": {
        "summary": "SignIn",
        "description": "Login with userName and password. Returns accessToken in respone and refreshToken in cookie.",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "Successful sign in",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "accessToken": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI2OTYwMDFjZDVmNTljOGQ5MjJjZDgzZDYiLCJpYXQiOjE2ODgwOTU5MDAsImV4cCI6MTY4ODE4MjMwMH0.DlX6KXJfXo3b8bXgW8y3u1vZg0kQ1F5Z3Z2Z3Z3Z3Z3"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "userName": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string",
                    "format": "color"
                  }
                },
                "required": ["userName", "password"]
              },
              "example": {
                "userName": "user2",
                "password": "123456"
              }
            }
          }
        }
      }
    },
    "/users/me": {
      "get": {
        "tags": ["User"],
        "summary": "AuthMe",
        "description": "Return the currently authenticated user's profile",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Current user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "User not found" }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "RefreshToken",
        "description": "Refresh access token using refresh token cookie",
        "responses": {
          "200": {
            "description": "Access token refreshed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SignInResponse" },
                "example": { "accessToken": "<jwt token>" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/friends/requests/{requestId}/accept": {
      "post": {
        "tags": ["Friend"],
        "summary": "AcceptFriendRequest",
        "description": "Accept a friend request by id",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "requestId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Friend request accepted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "message": { "type": "string" } }
                },
                "example": { "message": "Friend request accepted" }
              }
            }
          },
          "404": { "description": "Request not found" },
          "403": { "description": "Forbidden" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/friends/requests/{requestId}/decline": {
      "post": {
        "tags": ["Friend"],
        "summary": "DeclineFriendRequest",
        "description": "Decline a friend request by id",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "requestId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Friend request declined",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "message": { "type": "string" } }
                },
                "example": { "message": "Friend request declined" }
              }
            }
          },
          "404": { "description": "Request not found" },
          "403": { "description": "Forbidden" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/auth/signout": {
      "post": {
        "tags": ["Auth"],
        "summary": "SignOut",
        "description": "Clear refresh token cookie and delete the session for the current user",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "204": { "description": "Signed out" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/friends/": {
      "get": {
        "tags": ["Friend"],
        "summary": "GetAllFriends",
        "description": "Return a list of friends for the authenticated user",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of friends",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/User" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/messages/direct": {
      "post": {
        "tags": ["Message"],
        "summary": "SendDirectMessage",
        "description": "Send a direct message to a single user. If conversationId is omitted, a direct conversation will be created.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendDirectMessageRequest"
              },
              "example": {
                "recipientId": "695f159771170ef95bc5a238",
                "content": "Hello"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Message created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "403": { "description": "Forbidden (not friends)" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/messages/group": {
      "post": {
        "tags": ["Message"],
        "summary": "SendGroupMessage",
        "description": "Send a message to a group conversation. The caller must be a member of the conversation.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendGroupMessageRequest"
              },
              "example": {
                "conversationId": "696086b037233379e914fd11",
                "content": "hello everyone"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Message created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "403": { "description": "Forbidden (not a member)" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/conversations": {
      "post": {
        "tags": ["Conversation"],
        "summary": "CreateConversation",
        "description": "Create a new conversation (direct or group)",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateConversationRequest"
              },
              "example": {
                "type": "group",
                "name": "Group 1",
                "memberIds": [
                  "696001cd5f59c8d922cd83d6",
                  "695c930195272a868a107928"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Conversation created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Conversation" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "403": { "description": "Forbidden" },
          "500": { "description": "Server error" }
        }
      },
      "get": {
        "tags": ["Conversation"],
        "summary": "GetConversation",
        "description": "Return the authenticated user's conversations ordered by last message",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of conversations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Conversation" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/friends/requests": {
      "post": {
        "tags": ["Friend"],
        "summary": "SendFriendRequest",
        "description": "Send a friend request to another user",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/FriendRequest" },
              "example": {
                "to": "695f157371170ef95bc5a235",
                "message": "hello"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Friend request sent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "message": { "type": "string" } }
                },
                "example": { "message": "Friend request sent" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "403": { "description": "Forbidden" },
          "401": { "description": "Unauthorized" }
        }
      },
      "get": {
        "tags": ["Friend"],
        "summary": "GetFriendRequest",
        "description": "Return friend requests: sent (outgoing) and received (incoming). Supports pagination via `page` and `limit` query parameters and optional `filter` to search by displayName.\n\nExample request URL:\nGET http://localhost:5001/api/friends/requests?page=1&limit=10&filter=thanh\n\nExample curl:\ncurl -H \"Authorization: Bearer <token>\" \"http://localhost:5001/api/friends/requests?page=1&limit=10&filter=thanh\"",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 },
            "description": "Page number (1-based)"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 20 },
            "description": "Items per page"
          },
          {
            "name": "filter",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Optional filter string to search by displayName"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated friend requests",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "page": { "type": "integer" },
                    "limit": { "type": "integer" },
                    "totalSent": { "type": "integer" },
                    "totalReceived": { "type": "integer" },
                    "sent": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/FriendRequestItem"
                      }
                    },
                    "received": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/FriendRequestItem"
                      }
                    }
                  }
                },
                "example": {
                  "page": 1,
                  "limit": 10,
                  "totalSent": 2,
                  "totalReceived": 3,
                  "sent": [
                    {
                      "_id": "696...",
                      "to": { "_id": "695...", "displayName": "Target" },
                      "message": "hello",
                      "createdAt": "2026-01-10T12:00:00Z"
                    }
                  ],
                  "received": [
                    {
                      "_id": "697...",
                      "from": { "_id": "699...", "displayName": "Other" },
                      "message": "hi",
                      "createdAt": "2026-01-09T08:00:00Z"
                    }
                  ]
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "message": "Unauthorized" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "message": "system error" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "SignUpRequest": {
        "type": "object",
        "properties": {
          "userName": { "type": "string" },
          "password": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" }
        },
        "required": ["userName", "password", "email", "firstName", "lastName"]
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        }
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}
